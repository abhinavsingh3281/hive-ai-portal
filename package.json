{
  "name": "aisc",
  "private": true,
  "version": "0.1.0",
  "description": "Autonomous AI Software Company",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter server dev",
    "dev:all": "pnpm --parallel --filter './packages/*' --filter server --filter ui dev",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "db:generate": "pnpm --filter @aisc/db db:generate",
    "db:migrate": "pnpm --filter @aisc/db db:migrate",
    "db:studio": "pnpm --filter @aisc/db db:studio"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}