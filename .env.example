# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use embedded PGlite (zero-config local dev)
DATABASE_URL=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# ─── Storage ──────────────────────────────────────────────────────────────────
# Local disk by default; set to "s3" for production
STORAGE_TYPE=local
STORAGE_PATH=.aisc/storage
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# ─── AI Providers ─────────────────────────────────────────────────────────────
# API adapters — optional. CLI adapters (claude-cli, antigravity-cli) need no key.
ANTHROPIC_API_KEY=       # enables the 'claude' adapter (claude-opus-4-8)
GOOGLE_API_KEY=          # enables the 'gemini' adapter (gemini-1.5-pro)
GEMINI_API_KEY=          # enables the 'gemini-cli' adapter with API key auth

# ─── Scheduler ────────────────────────────────────────────────────────────────
# How often the heartbeat scheduler polls for pending work (ms)
SCHEDULER_INTERVAL_MS=15000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
